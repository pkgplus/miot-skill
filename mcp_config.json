{
  "mcpServers": {
    "miot-skill": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "miot_skill"],
      "env": {
        "MIOT_CACHE_DIR": "~/.miot-mcp"
      }
    },
    "miot-skill-remote": {
      "type": "sse",
      "url": "${XIAOZHI_MCP_URL}",
      "disabled": false
    }
  }
}
